# Copy to config/camera.env and fill in your stream URLs.
# All values can also be overridden per-run: docker compose run -e VAR=...

# ── Cameras ───────────────────────────────────────────────────────────────────
# UniFi Protect: enable the RTSPS stream per camera and paste its URL here.
RTSP_URL=rtsps://192.168.1.10:7441/YOUR_STREAM_TOKEN
# Package camera (overlaid bottom-right); leave unset to disable the PiP.
PKG_RTSP_URL=rtsps://192.168.1.10:7441/YOUR_PKG_STREAM_TOKEN

# Stream properties
RTSP_CODEC=h264
RTSP_LATENCY_MS=200
RTSP_PROTOCOLS=tcp

# To run from a local video file instead of live RTSP (e.g. for tuning):
# INPUT_VIDEO=/output/test.mp4
# FILE_MAX_FRAMES=1800

# ── Detection ─────────────────────────────────────────────────────────────────
# DETECTION_MODEL: yolo11 (default, Ultralytics) | stub
DETECTION_MODEL=yolo11
YOLO11_IMGSZ=640
DETECTION_THRESHOLD=0.50
MIN_DET_FRACTION=0.04
# Optional: comma-separated labels (lowercase). Empty → people-only default.
# DETECT_CLASS_FILTER=person

# ── Smart zoom ────────────────────────────────────────────────────────────────
ZOOM_PADDING=0.42
ZOOM_SMOOTH=0.14
ZOOM_OUT_HOLD=96
ZOOM_FOCUS_IOU_MIN=0.35
# "bottom" grows the 16:9 crop upward (avoids clipping foreheads on a high view).
# ZOOM_AR_HEIGHT_ANCHOR=bottom
# Extra room above a person box when the model has no face class.
# ZOOM_PERSON_TOP_PAD_FRAC=0.12

# ── ROI (optional; normalized x1,y1,x2,y2 — see tools/README_roi_label_tool.md)
# Run inference on a fixed crop so distant people are larger in NN input:
# INFERENCE_ROI_NORM=0.14,0.30,0.65,0.90
# Only targets whose bbox center falls here may become the zoom focus:
# ZOOM_ATTENTION_ROI_NORM=0.14,0.30,0.65,0.90

# ── FAR → CLOSE mode switching ────────────────────────────────────────────────
# CLOSE threshold is bbox height fraction (focus_bbox_height / frame_height).
CLOSE_FRAC_THRESHOLD=0.12
CLOSE_SUSTAIN_FRAMES=22
FULL_SNAPSHOT_EVERY_N_FRAMES=0
SNAPSHOT_FULL_SCALE=0.5

# ── Package cam overlay ───────────────────────────────────────────────────────
OVERLAY_FRACTION=0.25

# ── Output ────────────────────────────────────────────────────────────────────
SAVE_DETECTIONS=false
OUTPUT_DIR=/output

# ── Weather overlay (top-right) ───────────────────────────────────────────────
# Leave LAT/LON blank to auto-detect from public IP.
WEATHER_LAT=
WEATHER_LON=
WEATHER_UNIT=fahrenheit
WEATHER_REFRESH_MINUTES=30

# ── Web dashboard ─────────────────────────────────────────────────────────────
ENABLE_WEB=true
DISABLE_PKG_CAM=false
WEB_PORT=8080
# Resize to this width before JPEG-encoding the web stream (0 = native).
WEB_JPEG_WIDTH=1280
